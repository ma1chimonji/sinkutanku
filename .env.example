# =========================================
# Data Source
# =========================================
# microCMS のサービスドメイン（例: your-service）
MICROCMS_SERVICE_DOMAIN=
# microCMS の API Key（読み取り用）
MICROCMS_API_KEY=

# true にすると microCMS ではなく src/lib/mock-data.ts を使います
# ローカルの画面確認だけしたいときに便利です
USE_MOCK_DATA=true

# =========================================
# Cache Revalidation (Webhook)
# =========================================
# /api/revalidate の認証に使う共有シークレット
REVALIDATE_SECRET=
